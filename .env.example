POSTGRES_DB=mtg_prices
POSTGRES_USER=mtg_tracker
POSTGRES_PASSWORD=
POSTGRES_IMAGE=postgres:18-alpine
APP_PORT=8000
JACE_IMAGE=registry.example.com/jace-the-price-tracker:latest
JACE_DEFAULT_CURRENCY=eur
JACE_WEB_HOST=0.0.0.0
JACE_WEB_PORT=8000
JACE_REFRESH_INTERVAL_SECONDS=3600
JACE_SCRYFALL_BULK_SIZE=75
JACE_SCRYFALL_REQUEST_INTERVAL_SECONDS=0.12
JACE_SCRYFALL_COLLECTION_REQUEST_INTERVAL_SECONDS=0.55
JACE_SCRYFALL_TIMEOUT_SECONDS=20
JACE_IMAGE_FETCH_TIMEOUT_SECONDS=20
